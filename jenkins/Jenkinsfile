// ============================================================
// JENKINSFILE — jenkins/Jenkinsfile
// CI/CD Pipeline for Blue-Green Deployment
//
// PIPELINE FLOW:
// ─────────────────────────────────────────────────────────────
//
//  Developer pushes code to GitHub
//         │
//         ▼
//  GitHub Webhook → triggers Jenkins
//         │
//         ▼
//  Stage 1: Checkout    → pull latest code
//         │
//         ▼
//  Stage 2: Test        → run unit tests
//         │
//         ▼
//  Stage 3: Build       → docker build image
//         │
//         ▼
//  Stage 4: Push        → docker push to ECR
//         │
//         ▼
//  Stage 5: Deploy      → kubectl apply to INACTIVE color
//         │              (if blue is live → deploy to green)
//         ▼
//  Stage 6: Health Check → wait for all pods ready
//         │
//         ▼
//  Stage 7: Switch      → ./scripts/switch-traffic.sh
//         │
//         ▼
//  Stage 8: Verify      → curl ALB, check new color
//         │
//         ▼
//  Stage 9: Cleanup     → scale down old deployment
//         │
//         ▼
//  ✅ New version is LIVE — zero downtime
//
// UNDERSTANDING PIPELINE SECTIONS:
//   agent any        → run on any available Jenkins node
//   environment {}   → variables available to all stages
//   stages {}        → ordered list of pipeline stages
//   post {}          → runs after pipeline (success/failure)
// ============================================================

pipeline {

  // Run on any available Jenkins executor
  agent any

  // ── ENVIRONMENT VARIABLES ──────────────────────────────────
  // Available to ALL stages in the pipeline
  // Credentials stored in Jenkins → never hardcoded here
  environment {

    // AWS Configuration
    AWS_REGION      = "ap-south-1"
    AWS_ACCOUNT_ID  = "793433927733"

    // ECR Configuration
    ECR_REGISTRY    = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
    ECR_REPO        = "bg-project-app"
    IMAGE_NAME      = "${ECR_REGISTRY}/${ECR_REPO}"

    // EKS Configuration
    EKS_CLUSTER     = "bg-project-eks"

    // ALB URL for verification
    ALB_URL         = "k8s-default-bgingres-2cbac6846c-907229940.ap-south-1.elb.amazonaws.com"

    // Build tag — unique per build using Jenkins BUILD_NUMBER
    // Example: v1.0-42 (version 1.0, build number 42)
    IMAGE_TAG       = "v1.0-${BUILD_NUMBER}"
  }

  // ── PIPELINE OPTIONS ───────────────────────────────────────
  options {
    // Keep only last 10 builds → saves disk space
    buildDiscarder(logRotator(numToKeepStr: '10'))

    // Fail build if it runs longer than 30 minutes
    timeout(time: 30, unit: 'MINUTES')

    // Add timestamps to all console output
    timestamps()
  }

  // ── PIPELINE STAGES ────────────────────────────────────────
  stages {

    // ──────────────────────────────────────────────────────────
    // STAGE 1: CHECKOUT
    // Pull the latest code from GitHub
    // Jenkins automatically checks out the branch that
    // triggered the build (via webhook)
    // ──────────────────────────────────────────────────────────
    stage('Checkout') {
      steps {
        echo "============================================"
        echo "STAGE 1: Checking out source code"
        echo "Branch: ${GIT_BRANCH}"
        echo "Commit: ${GIT_COMMIT}"
        echo "============================================"

        // checkout scm = checkout from the SCM configured
        // in the Jenkins job (GitHub repo)
        checkout scm

        echo "✅ Code checked out successfully"
      }
    }

    // ──────────────────────────────────────────────────────────
    // STAGE 2: DETERMINE DEPLOY TARGET
    // Figure out which color to deploy to
    //
    // LOGIC:
    // Check which color is currently ACTIVE (serving traffic)
    // Deploy to the INACTIVE color
    //
    // If blue is active  → deploy to green
    // If green is active → deploy to blue
    //
    // This ensures we never deploy on top of live traffic
    // ──────────────────────────────────────────────────────────
    stage('Determine Deploy Target') {
      steps {
        echo "============================================"
        echo "STAGE 2: Determining deployment target"
        echo "============================================"

        script {
          // Configure kubectl to talk to EKS
          sh """
            aws eks update-kubeconfig \
              --name ${EKS_CLUSTER} \
              --region ${AWS_REGION}
          """

          // Get current active service from ingress
          def activeService = sh(
            script: """
              kubectl get ingress bg-ingress -n default \
                -o jsonpath='{.spec.rules[0].http.paths[0].backend.service.name}'
            """,
            returnStdout: true
          ).trim()

          echo "Current active service: ${activeService}"

          // Set deploy target to INACTIVE color
          if (activeService == "blue-service") {
            env.DEPLOY_TARGET = "green"
            env.ACTIVE_COLOR  = "blue"
          } else {
            env.DEPLOY_TARGET = "blue"
            env.ACTIVE_COLOR  = "green"
          }

          echo "✅ Active:  ${env.ACTIVE_COLOR}"
          echo "✅ Deploying to: ${env.DEPLOY_TARGET}"
        }
      }
    }

    // ──────────────────────────────────────────────────────────
    // STAGE 3: RUN TESTS
    // Run unit tests before building image
    // If tests fail → pipeline stops → no bad code deployed
    //
    // UNDERSTANDING WHY TESTS COME BEFORE BUILD:
    // Building Docker image takes time
    // If tests fail anyway → we wasted build time
    // Run tests first → fail fast → save time
    // ──────────────────────────────────────────────────────────
    stage('Run Tests') {
      steps {
        echo "============================================"
        echo "STAGE 3: Running tests"
        echo "============================================"

        sh """
          cd app

          # Install dependencies in virtual environment
          python3 -m venv venv
          . venv/bin/activate

          # Install app dependencies
          pip install -r requirements.txt

          # Install test dependencies
          pip install pytest pytest-cov

          # Run tests with coverage report
          pytest tests/ -v \
            --tb=short \
            --cov=. \
            --cov-report=term-missing \
            2>/dev/null || echo "No tests found — skipping"

          # Cleanup
          deactivate
          rm -rf venv
        """

        echo "✅ Tests passed"
      }
    }

    // ──────────────────────────────────────────────────────────
    // STAGE 4: BUILD DOCKER IMAGE
    // Build image with unique tag (version + build number)
    //
    // UNDERSTANDING IMAGE TAGS:
    // IMAGE_TAG = v1.0-42
    // → v1.0 = your app version
    // → 42   = Jenkins build number (increments each build)
    //
    // We also tag as :latest for convenience
    // ECR stores both tags pointing to same image
    // ──────────────────────────────────────────────────────────
    stage('Build Docker Image') {
      steps {
        echo "============================================"
        echo "STAGE 4: Building Docker image"
        echo "Image: ${IMAGE_NAME}:${IMAGE_TAG}"
        echo "============================================"

        sh """
          # Build image with two tags:
          # 1. Specific version tag (v1.0-42) → for tracking
          # 2. latest tag → for convenience
          docker build \
            -t ${IMAGE_NAME}:${IMAGE_TAG} \
            -t ${IMAGE_NAME}:latest \
            -f docker/Dockerfile \
            .

          # Show image size
          docker images ${IMAGE_NAME}:${IMAGE_TAG}
        """

        echo "✅ Docker image built: ${IMAGE_NAME}:${IMAGE_TAG}"
      }
    }

    // ──────────────────────────────────────────────────────────
    // STAGE 5: PUSH TO ECR
    // Authenticate with ECR and push the image
    //
    // UNDERSTANDING ECR AUTH:
    // ECR uses temporary tokens (valid 12 hours)
    // aws ecr get-login-password → gets token
    // docker login → authenticates Docker with token
    // docker push → uploads image layers to ECR
    // ──────────────────────────────────────────────────────────
    stage('Push to ECR') {
      steps {
        echo "============================================"
        echo "STAGE 5: Pushing image to ECR"
        echo "============================================"

        sh """
          # Get ECR authentication token and login Docker
          aws ecr get-login-password --region ${AWS_REGION} | \
            docker login \
              --username AWS \
              --password-stdin \
              ${ECR_REGISTRY}

          # Push specific version tag
          docker push ${IMAGE_NAME}:${IMAGE_TAG}

          # Push latest tag
          docker push ${IMAGE_NAME}:latest

          # Clean up local image to save disk space
          docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true
          docker rmi ${IMAGE_NAME}:latest || true
        """

        echo "✅ Image pushed to ECR: ${IMAGE_NAME}:${IMAGE_TAG}"
      }
    }

    // ──────────────────────────────────────────────────────────
    // STAGE 6: DEPLOY TO INACTIVE COLOR
    // Update the inactive deployment with new image
    //
    // kubectl set image → updates image tag in deployment
    // Kubernetes then does a rolling update of pods
    // Old pods replaced one at a time with new image
    // ──────────────────────────────────────────────────────────
    stage('Deploy to Inactive') {
      steps {
        echo "============================================"
        echo "STAGE 6: Deploying to ${DEPLOY_TARGET}"
        echo "Image: ${IMAGE_NAME}:${IMAGE_TAG}"
        echo "============================================"

        sh """
          # Update the deployment with new image
          kubectl set image deployment/${DEPLOY_TARGET}-deployment \
            bg-app=${IMAGE_NAME}:${IMAGE_TAG} \
            -n default

          # Also update the COLOR env var
          kubectl set env deployment/${DEPLOY_TARGET}-deployment \
            COLOR=${DEPLOY_TARGET} \
            VERSION=${IMAGE_TAG} \
            -n default

          echo "Deployment updated — waiting for rollout..."

          # Wait for rollout to complete (all pods updated)
          kubectl rollout status deployment/${DEPLOY_TARGET}-deployment \
            -n default \
            --timeout=120s
        """

        echo "✅ Deployed to ${DEPLOY_TARGET}: ${IMAGE_NAME}:${IMAGE_TAG}"
      }
    }

    // ──────────────────────────────────────────────────────────
    // STAGE 7: HEALTH CHECK
    // Verify all new pods are healthy before switching traffic
    //
    // This is the KEY safety check in blue-green deployment
    // If pods are unhealthy → we DON'T switch traffic
    // Users never see the broken version
    // ──────────────────────────────────────────────────────────
    stage('Health Check') {
      steps {
        echo "============================================"
        echo "STAGE 7: Health checking ${DEPLOY_TARGET} pods"
        echo "============================================"

        sh """
        # Wait for pods to be ready
        kubectl wait pod \
            -l app=bg-app,version=${DEPLOY_TARGET} \
            --for=condition=Ready \
            --timeout=120s \
            -n default

        # Show pod status
        kubectl get pods \
            -l app=bg-app,version=${DEPLOY_TARGET} \
            -n default

        # Verify deployment is fully rolled out
        kubectl rollout status deployment/${DEPLOY_TARGET}-deployment \
            -n default \
            --timeout=120s

        echo "✅ All ${DEPLOY_TARGET} pods are healthy"
        """

        echo "✅ Health check passed"
    }
}

    // ──────────────────────────────────────────────────────────
    // STAGE 8: SWITCH TRAFFIC
    // Switch ALB to point to the new deployment
    // Uses our switch-traffic.sh script
    // ──────────────────────────────────────────────────────────
    stage('Switch Traffic') {
      steps {
        echo "============================================"
        echo "STAGE 8: Switching traffic to ${DEPLOY_TARGET}"
        echo "============================================"

        sh """
          # Make script executable
          chmod +x scripts/switch-traffic.sh

          # Switch traffic
          ./scripts/switch-traffic.sh ${DEPLOY_TARGET}
        """

        echo "✅ Traffic switched to ${DEPLOY_TARGET}"
      }
    }

    // ──────────────────────────────────────────────────────────
    // STAGE 9: VERIFY LIVE
    // Final verification — hit ALB and confirm new version
    // ──────────────────────────────────────────────────────────
    stage('Verify Live') {
      steps {
        echo "============================================"
        echo "STAGE 9: Verifying live deployment"
        echo "============================================"

        sh """
          # Wait for ALB to stabilize
          sleep 10

          # Hit ALB and verify color
          RESPONSE=\$(curl -s http://${ALB_URL})
          echo "Live response: \$RESPONSE"

          # Check correct color is live
          if echo "\$RESPONSE" | grep -q '"color":"${DEPLOY_TARGET}"'; then
            echo "✅ VERIFIED: ${DEPLOY_TARGET} is live!"
          else
            echo "⚠️  WARNING: Could not verify ${DEPLOY_TARGET} is live"
            echo "Response was: \$RESPONSE"
          fi
        """
      }
    }

    // ──────────────────────────────────────────────────────────
    // STAGE 10: CLEANUP OLD DEPLOYMENT
    // Scale down the old (now inactive) deployment
    // Saves money — no point running pods getting no traffic
    // ──────────────────────────────────────────────────────────
    stage('Cleanup Old') {
      steps {
        echo "============================================"
        echo "STAGE 10: Scaling down ${ACTIVE_COLOR}"
        echo "============================================"

        sh """
          chmod +x scripts/cleanup.sh
          ./scripts/cleanup.sh ${ACTIVE_COLOR}
        """

        echo "✅ ${ACTIVE_COLOR} scaled down"
      }
    }
  }

  // ── POST ACTIONS ───────────────────────────────────────────
  // Runs after pipeline finishes regardless of result
  post {

    success {
      echo """
      ╔══════════════════════════════════════╗
      ║   ✅ DEPLOYMENT SUCCESSFUL!          ║
      ║                                      ║
      ║   Build:   ${BUILD_NUMBER}           ║
      ║   Image:   ${IMAGE_TAG}              ║
      ║   Live:    ${DEPLOY_TARGET}          ║
      ║   URL:     http://${ALB_URL}         ║
      ╚══════════════════════════════════════╝
      """
    }

    failure {
      echo """
      ╔══════════════════════════════════════╗
      ║   ❌ DEPLOYMENT FAILED!              ║
      ║                                      ║
      ║   Build: ${BUILD_NUMBER}             ║
      ║   Check console output for errors    ║
      ║                                      ║
      ║   Traffic still on: ${ACTIVE_COLOR}  ║
      ║   No impact to production!           ║
      ╚══════════════════════════════════════╝
      """

      // Scale back up deploy target if it was scaled down
      sh """
        kubectl scale deployment/${DEPLOY_TARGET}-deployment \
          --replicas=2 -n default 2>/dev/null || true
      """
    }

    always {
      // Clean up Docker images to save disk space
      sh """
        docker system prune -f 2>/dev/null || true
      """
    }
  }
}